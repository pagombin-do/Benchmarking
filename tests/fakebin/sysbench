#!/usr/bin/env python3
"""Fake sysbench for end-to-end tests: emits realistic output instantly.

Knobs (env vars):
  FAKE_SYSBENCH_FAIL_THREADS  comma-separated thread counts whose `run` fails
                              with the worker-init FATAL and exit code 1.
  FAKE_SYSBENCH_RUN_FAIL_THREADS  thread counts whose `run` prints a PostgreSQL
                              FATAL and exits 2 with ZERO interval lines (mirrors
                              the field soak: tpcc dies in init before reporting).
  FAKE_SYSBENCH_HANG_THREADS  thread counts whose `run` starts then hangs forever
                              (no output, no exit) — exercises the segment watchdog.
  FAKE_SYSBENCH_COUNT_FILE    file to append one line per `run` invocation.
"""
import os
import sys
import time

args = sys.argv[1:]

if "--version" in args:
    print("sysbench 1.0.20 (using bundled LuaJIT 2.1.0-beta2)")
    sys.exit(0)


def opt(name, default):
    for a in args:
        if a.startswith(f"--{name}="):
            return a.split("=", 1)[1]
    return default


action = args[-1] if args else ""
threads = int(opt("threads", "1"))
duration = int(opt("time", "5"))

count_file = os.environ.get("FAKE_SYSBENCH_COUNT_FILE")
if count_file and action == "run":
    with open(count_file, "a") as fh:
        fh.write(f"run threads={threads}\n")

if action == "prepare":
    print("Creating tables and loading data...")
    state = os.environ.get("FAKE_PSQL_STATE")
    # FAKE_SYSBENCH_NO_MARKER simulates a prepare that exits 0 but creates
    # nothing (e.g. silently wrote to the wrong place).
    if state and not os.environ.get("FAKE_SYSBENCH_NO_MARKER"):
        with open(os.path.join(state, "prepared"), "w") as fh:
            fh.write("1\n")  # makes the fake psql report a fully loaded dataset
    sys.exit(0)

if action != "run":
    print(f"fake sysbench: unknown action {action!r}", file=sys.stderr)
    sys.exit(1)

print("sysbench 1.0.20 (using bundled LuaJIT 2.1.0-beta2)\n")
print(f"Number of threads: {threads}")
print("Report intermediate results every 1 second(s)\n")
print("Initializing worker threads...\n")

def _threadset(name):
    return {int(x) for x in os.environ.get(name, "").split(",") if x}


fail_threads = _threadset("FAKE_SYSBENCH_FAIL_THREADS")
if threads in fail_threads:
    print("FATAL: PQsetdbLogin() failed: ERROR:  no more connections allowed (max_client_conn)")
    print("FATAL: Worker threads failed to initialize within 30 seconds!")
    sys.exit(1)

# Mimic the field soak: tpcc dies during per-thread init with a PostgreSQL FATAL
# and exit code 2, emitting ZERO interval lines.
if threads in _threadset("FAKE_SYSBENCH_RUN_FAIL_THREADS"):
    print("FATAL: PQexec() failed: ERROR:  deadlock detected")
    print("FATAL: `thread_init' function failed: tpcc.lua:...: SQL error")
    sys.exit(2)

# Connect then hang: no output, never exits — the supervisor watchdog must kill it.
if threads in _threadset("FAKE_SYSBENCH_HANG_THREADS"):
    print("Threads started!\n", flush=True)
    time.sleep(3600)
    sys.exit(0)

print("Threads started!\n")
base_tps = 100.0 * threads
for t in range(1, duration + 1):
    tps = base_tps * (0.8 if t == 1 else 1.0) + t * 0.5
    qps = tps * 20
    r, w, o = qps * 0.5, qps * 0.33, qps * 0.17
    # Mimic real sysbench-tpcc: "err/s" has NO colon (regression guard).
    print(f"[ {t}s ] thds: {threads} tps: {tps:.2f} qps: {qps:.2f} "
          f"(r/w/o: {r:.2f}/{w:.2f}/{o:.2f}) lat (ms,99%): {45.79 + t:.2f} "
          f"err/s 0.00 reconn/s: 0.00")

if "--histogram" in args:
    print("Latency histogram (values are in milliseconds)")
    print("       value  ------------- distribution ------------- count")
    for value, count in [(4.91, 30), (9.22, 400), (17.32, 900),
                         (32.53, 400), (61.08, 60), (114.72, 5)]:
        print(f"{value:>12.3f} |{'*' * min(40, count // 25):<41}{count}")
    print()

total_tx = int(base_tps * duration)
print(f"""SQL statistics:
    queries performed:
        read:                            {total_tx * 10}
        write:                           {total_tx * 7}
        other:                           {total_tx * 3}
        total:                           {total_tx * 20}
    transactions:                        {total_tx}  ({base_tps:.2f} per sec.)
    queries:                             {total_tx * 20} ({base_tps * 20:.2f} per sec.)
    ignored errors:                      0      (0.00 per sec.)
    reconnects:                          0      (0.00 per sec.)

General statistics:
    total time:                          {duration}.0012s
    total number of events:              {total_tx}

Latency (ms):
         min:                                    2.32
         avg:                                   18.12
         max:                                  225.65
         99th percentile:                       46.79
         sum:                              1919868.86

Threads fairness:
    events (avg/stddev):           192.8906/4.21
    execution time (avg/stddev):   {duration}.9979/0.01""")
sys.exit(0)
