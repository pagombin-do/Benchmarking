#!/usr/bin/env python3
"""Fake psql for end-to-end tests.

Knobs (env vars):
  FAKE_PSQL_TABLES     count of expected tables resolving on search_path
                       (default: all; forced to all once the prepared marker exists)
  FAKE_PSQL_WRONG_SCHEMA  schema name: simulate tables created off the search_path
                       (resolvable count = 0, but found in this schema)
  FAKE_PSQL_FOREIGN    count of non-benchmark tables (default 0)
  FAKE_PSQL_ROWS       warehouse1 row count for tpcc scale checks (default 30)
  FAKE_PSQL_MAX_ID     max(id) of sbtest1 for oltp size checks (default 1000)
  FAKE_PSQL_CANARY_COLS override the canary column-count answer
  FAKE_PSQL_MAX_CONN   simulate a pooler ceiling: pg_sleep connections beyond
                       this count are refused with PgBouncer's error.
                       Requires FAKE_PSQL_STATE (a writable directory).

A `prepared` marker file in FAKE_PSQL_STATE (written by the fake sysbench's
`prepare`) makes the dataset look fully loaded regardless of FAKE_PSQL_TABLES.
"""
import fcntl
import os
import re
import sys
import time

args = sys.argv[1:]

if "--version" in args:
    print("psql (PostgreSQL) 16.4 (Ubuntu 16.4-1)")
    sys.exit(0)

sql = ""
for i, a in enumerate(args):
    if a == "-c" and i + 1 < len(args):
        sql = args[i + 1]

if not os.environ.get("PGPASSWORD"):
    print("psql: error: connection failed: fe_sendauth: no password supplied",
          file=sys.stderr)
    sys.exit(2)

low = sql.lower()

if "pg_sleep" in low:
    max_conn = os.environ.get("FAKE_PSQL_MAX_CONN")
    if max_conn:
        state = os.environ["FAKE_PSQL_STATE"]
        counter = os.path.join(state, "conn_counter")
        with open(counter, "a+") as fh:
            fcntl.flock(fh, fcntl.LOCK_EX)
            fh.seek(0)
            n = int(fh.read().strip() or "0") + 1
            fh.seek(0)
            fh.truncate()
            fh.write(str(n))
        if n > int(max_conn):
            print("psql: error: connection to server failed: FATAL:  "
                  "no more connections allowed (max_client_conn)", file=sys.stderr)
            sys.exit(2)
    m = re.search(r"pg_sleep\((\d+)", low)
    time.sleep(min(int(m.group(1)) if m else 1, 60))
    print("")
    sys.exit(0)

def names_in_list(sql_text):
    """Count quoted names inside the first IN (...) list of the statement."""
    m = re.search(r"in \(([^)]*)\)", sql_text)
    return len(re.findall(r"'[^']*'", m.group(1))) if m else 0


TABLE_RE = re.compile(
    r"^(sbtest|warehouse|district|customer|history|orders|new_orders|"
    r"order_line|stock|item)\d+$")


def table_names(sql_text):
    """All quoted table-like names referenced in the statement."""
    return [s for s in re.findall(r"'([^']*)'", sql_text) if TABLE_RE.match(s)]


state_dir = os.environ.get("FAKE_PSQL_STATE", "")
prepared = state_dir and os.path.exists(os.path.join(state_dir, "prepared"))
wrong_schema = os.environ.get("FAKE_PSQL_WRONG_SCHEMA")

if low == "select 1":
    print("1")
elif "select version()" in low:
    print("PostgreSQL 16.4 on x86_64-pc-linux-gnu, compiled by gcc 13.2.0, 64-bit")
elif "show server_version" in low:
    print("16.4")
elif "show max_connections" in low:
    print("500")
elif "show search_path" in low:
    print('"$user", public')
elif "show pool_mode" in low:
    print('ERROR:  unrecognized configuration parameter "pool_mode"', file=sys.stderr)
    sys.exit(1)
elif "pg_extension" in low:
    print("0")
elif "to_regclass" in low and "values" in low:
    # count of expected tables resolving on the search_path
    names = table_names(sql)
    if wrong_schema:
        print("0")
    elif prepared:
        print(len(names))
    else:
        print(os.environ.get("FAKE_PSQL_TABLES", str(len(names))))
elif "pg_tables" in low and "not in" in low:
    print(os.environ.get("FAKE_PSQL_FOREIGN", "0"))
elif "pg_tables" in low:
    # find expected tables in ANY schema
    if wrong_schema:
        for n in table_names(sql):
            print(f"{wrong_schema}.{n}")
elif "pg_attribute" in low or "information_schema.columns" in low:
    print(os.environ.get("FAKE_PSQL_CANARY_COLS", str(names_in_list(low))))
elif "max(id) from sbtest1" in low:
    print(os.environ.get("FAKE_PSQL_MAX_ID", "1000"))
elif "pg_stat_activity" in low:
    # live PG sampler: cumulative counters grow with wall-clock so deltas > 0.
    import json as _json
    n = int(time.time())
    print(_json.dumps({
        "db_epoch": time.time(),
        "active": 8, "total_conn": 20,
        "blocked": int(os.environ.get("FAKE_PSQL_BLOCKED", "2")),
        "lock_wait_max_s": float(os.environ.get("FAKE_PSQL_LOCK_WAIT", "0.4")),
        "xact_commit": n * 90, "xact_rollback": n * 10, "xacts": n * 100,
        "blks_hit": n * 9000, "blks_read": n * 100, "wal_bytes": n * 500000,
        "tup_returned": n * 5000, "tup_fetched": n * 4000, "tup_inserted": n * 300,
        "tup_updated": n * 200, "tup_deleted": n * 50,
        "deadlocks": 0, "conflicts": 0, "temp_bytes": n * 1000, "temp_files": n * 1,
        "ckpt_timed": n // 10, "ckpt_req": 0, "ckpt_write_ms": n * 5, "ckpt_sync_ms": n * 1,
        "bgw_clean": n * 20, "bgw_alloc": n * 100, "repl_replay_lag": None}))
elif "from pg_database where datname" in low:
    # database existence check for prepare create/recreate
    print(os.environ.get("FAKE_PSQL_DB_EXISTS", "1"))
elif low.startswith("create database") or low.startswith("drop database") or "pg_terminate_backend" in low:
    pass  # admin op succeeds silently
elif low.startswith("create extension"):
    pass  # pg_stat_monitor enable succeeds
elif low.startswith("drop table"):
    pass  # table drop succeeds
elif "pg_database_size" in low:
    print("1073741824")
elif "pg_stat_bgwriter" in low:
    print('{"checkpoints_timed":12,"checkpoints_req":3,"buffers_clean":4567}')
elif "pg_stat_io" in low:
    # monotonic-ish counters driven by a per-state call counter
    state = os.environ.get("FAKE_PSQL_STATE", "")
    n = 0
    if state:
        cf = os.path.join(state, "io_counter")
        try:
            n = int(open(cf).read().strip())
        except (OSError, ValueError):
            n = 0
        with open(cf, "w") as fh:
            fh.write(str(n + 1))
    base = n * 1000
    print('{"reads": %d, "writes": %d, "extends": %d, "fsyncs": %d, "hits": %d}'
          % (base, base // 2, base // 10, base // 20, base * 9))
elif "pg_stat_database" in low:
    state = os.environ.get("FAKE_PSQL_STATE", "")
    n = 0
    if state:
        cf = os.path.join(state, "db_counter")
        try:
            n = int(open(cf).read().strip())
        except (OSError, ValueError):
            n = 0
        with open(cf, "w") as fh:
            fh.write(str(n + 1))
    print('{"blks_read": %d, "blks_hit": %d}' % (n * 500, n * 4500))
elif "pg_stat_wal" in low:
    state = os.environ.get("FAKE_PSQL_STATE", "")
    n = 0
    if state:
        cf = os.path.join(state, "wal_counter")
        try:
            n = int(open(cf).read().strip())
        except (OSError, ValueError):
            n = 0
        with open(cf, "w") as fh:
            fh.write(str(n + 1))
    print('{"wal_records": %d, "wal_bytes": %d, "wal_fpi": %d}' % (n * 2000, n * 8000000, n * 50))
elif "pg_stat_monitor" in low:
    print("[]")
elif "copy (select name, setting, unit, source from pg_settings" in low:
    print("name,setting,unit,source")
    rows = [
        ("checkpoint_timeout", "300", "s", "default"),
        ("effective_cache_size", "786432", "8kB", "configuration file"),
        ("huge_pages", "try", "", "default"),
        ("max_connections", "500", "", "configuration file"),
        ("max_wal_size", "4096", "MB", "configuration file"),
        ("random_page_cost", "1.1", "", "configuration file"),
        ("shared_buffers", os.environ.get("FAKE_PSQL_SHARED_BUFFERS", "262144"), "8kB",
         "configuration file"),
        ("synchronous_commit", "on", "", "default"),
        ("wal_buffers", "2048", "8kB", "default"),
        ("work_mem", os.environ.get("FAKE_PSQL_WORK_MEM", "4096"), "kB", "default"),
    ]
    for r in rows:
        print(",".join(r))
elif "count(*) from warehouse1" in low:
    print(os.environ.get("FAKE_PSQL_ROWS", "30"))
elif low.startswith("select count(*)"):
    print("0")
else:
    print(f"fake psql: unhandled SQL: {sql}", file=sys.stderr)
    sys.exit(1)
sys.exit(0)
