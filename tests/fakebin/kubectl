DIAG_SEP = "\x1f"


def pg_catalog_rows(st):
    """pg_settings rows (dicts) for the json_agg catalog query."""
    params = (st["cr"]["spec"]["patroni"]["dynamicConfiguration"]["postgresql"]
              ["parameters"])
    rows = []
    for name in sorted(PG_CATALOG):
        setting, unit, vartype, mn, mx, enums, context, cat, desc = PG_CATALOG[name]
        live = str(params.get(name, setting))
        rows.append({
            "name": name, "setting": live, "unit": unit, "vartype": vartype,
            "min_val": mn, "max_val": mx, "enumvals": enums, "context": context,
            "category": cat, "short_desc": desc, "boot_val": setting,
            "reset_val": live,
            "source": "configuration file" if name in params else "default",
            "pending_restart": name in st.get("pending_restart", []),
        })
    return rows


def run_sql(st, sql):
    """Answer the SQL the ops runners issue, from cluster state."""
    s = " ".join(sql.split()).lower()
    params = (st["cr"]["spec"]["patroni"]["dynamicConfiguration"]["postgresql"]
              ["parameters"])
    j = DIAG_SEP.join
    # ── marker-dispatched queries (params catalog, diag, health) ──
    # These must run before the generic substring branches below.
    if "json_agg" in s and "pg_settings" in s:
        return json.dumps(pg_catalog_rows(st))
    if "show server_version" in s:
        return "18.0"
    if "show shared_preload_libraries" in s:
        return str(params.get("shared_preload_libraries", "pgaudit"))
    if "from pg_extension" in s and "extversion" in s:
        return "\n".join(f"{e}|1.0"
                         for e in sorted(st.get("extensions", ["pgaudit"])))
    if "from pg_extension" in s:      # SELECT 1 FROM pg_extension WHERE extname='X'
        return "1" if any(f"'{e}'" in s
                          for e in st.get("extensions", ["pgaudit"])) else ""
    if "diag:connections" in s or "health:connections" in s:
        used, mx = 12, int(params.get("max_connections", 100))
        if "health:" in s:
            return j([str(used), str(mx)])
        return j(["12", "3", "8", "1", "0", str(mx),
                  str(round(100.0 * used / mx, 1))])
    if "health:idle_tx" in s:
        return j(["0", "0"]) if not os.environ.get("FAKE_KUBE_IDLE_TX") \
            else j(["2", os.environ["FAKE_KUBE_IDLE_TX"]])
    if "health:longtx" in s:
        return "42"
    if "diag:long_running" in s:
        return j(["4242", "doadmin", "active", "", "42",
                  "SELECT * FROM sbtest1 WHERE id = $1"])
    if "diag:blocked" in s:
        return ""
    if "diag:replication" in s or "health:slots" in s or "diag:slots" in s:
        replicas = [i for i in st["instances"]
                    if i["name"] != st["leader"] and pod_alive(st, i["name"])]
        if "health:slots" in s:
            if os.environ.get("FAKE_KUBE_INACTIVE_SLOT"):
                return j([str(2 << 30), "1"])
            return j(["0", "0"])
        if "diag:slots" in s:
            rows = [j([f"{r['name']}_slot", "physical", "true", "8388608"])
                    for r in replicas]
            if os.environ.get("FAKE_KUBE_INACTIVE_SLOT"):
                rows.append(j(["orphaned_slot", "physical", "false", str(2 << 30)]))
            return "\n".join(rows)
        return "\n".join(j([r["name"], "streaming", "1024", "2048", "0.1"])
                         for r in replicas)
    if "diag:wraparound" in s or "health:wraparound" in s:
        if "health:" in s:
            return "180000000"
        return "\n".join([j(["defaultdb", "180000000", "8.38"]),
                          j(["postgres", "120000000", "5.59"])])
    if "diag:cache_hit" in s or "health:cache_hit" in s:
        if "health:" in s:
            return "0.9987"
        return j(["defaultdb", "3212", "2453411", "0.9987"])
    if "health:pending" in s:
        return str(len(st.get("pending_restart", [])))
    if "diag:dead_tuples" in s:
        return "\n".join([j(["public.sbtest1", "1000000", "52000", "4.9",
                             "2026-07-10 01:00:00+00"]),
                          j(["public.sbtest2", "1000000", "1200", "0.1", "never"])])
    if "diag:table_sizes" in s:
        return "\n".join([j(["public.sbtest1", "2147483648", "2048 MB"]),
                          j(["public.sbtest2", "1073741824", "1024 MB"])])
    if "diag:temp_files" in s:
        return j(["defaultdb", "3", "104857600"])
    if "diag:checkpoints" in s:
        return j(["48", "9", "15.8"])
    if "op:shared_buffers" in s:
        return str(16384 * 8192)
    if "diag:wal_activity" in s:
        return j([str((int(now()) % 100000) * 1048576), "5/AB000000"])
    if "pg_stat_archiver" in s:
        n = st["archived_base"] + int(now()) % 100000
        return (f"{int(now())},{n},0,0000000500000000000000AB,"
                f"{int(now()) - 2},,0")
    if "pg_settings" in s:
        rows = []
        for name in sorted(PG_DEFAULTS):
            val, unit = PG_DEFAULTS[name]
            val = str(params.get(name, val))
            pending = "t" if name in st.get("pending_restart", []) else "f"
            rows.append(f"{name}|{val}|{unit}|{pending}")
        return "\n".join(rows)
    if "pg_stat_reset_shared" in s:
        return ""
    if "pg_stat_wal" in s or "wal_bytes" in s:
        if "extract(epoch" in s:
            return f"{int(now())},{(int(now()) % 100000) * 1048576},128"
        return str((int(now()) % 100000) * 1048576)
    if "checkpoints" in s or "pg_stat_checkpointer" in s or "pg_stat_bgwriter" in s:
        return f"{int(now()) % 500},{int(now()) % 37}"
    if "pg_stat_replication" in s:
        lines = []
        for i in st["instances"]:
            if i["name"] != st["leader"] and pod_alive(st, i["name"]):
                lines.append(f"{i['name']},streaming,1024,0.5")
        return "\n".join(lines)
    if "pg_database_size" in s:
        return "13100000000"
    if "clock_timestamp" in s:
        # probe-style query answered inside the pod (not via pgbouncer)
        from datetime import datetime, timezone
        ts = datetime.now(timezone.utc).isoformat()
        return f"{ts}|f|10.244.0.20"
    return ""


def archive_queue_depth(st):
    if backup_running(st):
        elapsed = now() - (st.get("backup_until", 0) - BACKUP_S)
        return min(32, 3 + int(elapsed * 15))
    return 3


def handle_exec(st, pod, argv):
    joined = " ".join(argv)
    if argv[0] == "cat" and "/proc/self/mountinfo" in joined:
        out(MOUNTINFO)
        return 0
    if argv[0] == "cat" and "/proc/diskstats" in joined:
        out(diskstats_text())
        return 0
    if argv[0] == "sh" and "diskstats" in joined and "while" in joined:
        # FAKE_KUBE_STREAM_DIE_S: the stream dies after N seconds (rc 1) —
        # exercises the sampler's auto-respawn on long runs
        die = float(os.environ.get("FAKE_KUBE_STREAM_DIE_S", "0"))
        deadline = now() + (die or float(os.environ.get("FAKE_KUBE_LOG_FOLLOW_S", "30")))
        while now() < deadline:
            out(str(int(now() * 1000)))
            out(diskstats_text())
            out("===")
            sys.stdout.flush()
            time.sleep(1)
        return 1 if die else 0
    if argv[0] == "df" and "-Pk" in argv:
        out("Filesystem 1024-blocks Used Available Capacity Mounted on")
        out(f"/dev/nvme1n1 524288000 104857600 "
            f"{os.environ.get('FAKE_KUBE_DF_AVAIL_KB', '419430400')} 20% /pgdata")
        return 0
    if argv[0] == "mkdir":
        return 0
    if argv[0] == "sh" and "rm -rf" in joined:
        st["probe_files"] = False
        save(st)
        return 0
    if argv[0] == "sh" and "ls /pgdata/pgb-fileio-probe" in joined:
        return 0 if st.get("probe_files") else 1
    if argv[0] == "sh" and "stat -c %s /pgdata/pgb-fileio-probe" in joined:
        # geometry check: first-file size (or MISSING) + last-file presence
        if st.get("probe_files"):
            out(str(st.get("probe_file_bytes", 0)))
            want_last = f"test_file.{st.get('probe_file_num', 1) - 1} "
            out("LAST-YES" if want_last in joined + " " else "LAST-NO")
        else:
            out("MISSING")
            out("LAST-NO")
        return 0
    if "sysbench" in joined and "fileio" in joined:
        t_arg = next((a.split("=", 1)[1] for a in joined.split()
                      if a.startswith("--time=")), "0")
        if joined.rstrip().endswith("prepare"):
            st["probe_files"] = True
            args = {a.split("=", 1)[0]: a.split("=", 1)[1]
                    for a in joined.split() if "=" in a}
            num = int(args.get("--file-num", "128"))
            size_mb = int(args.get("--file-total-size", "1024M").rstrip("MG"))
            st["probe_file_num"] = num
            st["probe_file_bytes"] = size_mb * 1048576 // num
            save(st)
            out("128 files, 8192Kb each, 1024Mb total")
            out("Creating files for the test...")
            return 0
        if joined.rstrip().endswith("cleanup"):
            out("Removing test files...")
            return 0
        run_t = min(int(t_arg or 1), 20)
        time.sleep(run_t)                      # let the device sampler collect
        r, w = DEV_IOPS * 0.6, DEV_IOPS * 0.4
        out("sysbench 1.0.20 (using bundled LuaJIT 2.1.0-beta2)\n")
        out("File operations:")
        out(f"    reads/s:                      {r:.2f}")
        out(f"    writes/s:                     {w:.2f}")
        out("    fsyncs/s:                     0.00\n")
        out("Throughput:")
        out(f"    read, MiB/s:                  {r * 16 / 1024:.2f}")
        out(f"    written, MiB/s:               {w * 16 / 1024:.2f}")
        return 0
    if argv[0] == "patronictl":
        if argv[1] == "list":
            out(patronictl_list(st))
            return 0
        if argv[1] == "show-config":
            pat = st["cr"]["spec"].get("patroni", {})
            dcs = json.loads(json.dumps(pat.get("dynamicConfiguration", {})))
            dcs["ttl"] = pat.get("leaderLeaseDurationSeconds", 30)
            dcs["loop_wait"] = pat.get("syncPeriodSeconds", 10)
            dcs.setdefault("retry_timeout", 10)
            out(json.dumps(dcs, indent=1))
            return 0
        if argv[1] in ("switchover", "failover"):
            cand = None
            if "--candidate" in argv:
                cand = argv[argv.index("--candidate") + 1]
            candidates = [i["name"] for i in st["instances"]
                          if i["name"] != st["leader"] and pod_alive(st, i["name"])]
            if cand is not None:
                if cand not in candidates:
                    sys.stderr.write(f"candidate {cand} is not a running replica\n")
                    return 1
                candidates = [cand]
            if not candidates:
                sys.stderr.write("no candidates for switchover\n")
                return 1
            st["killed_at"] = now() - RESTART_S + BLIP_S   # brief write blip
            st["leader"] = candidates[0]
            st["tl"] += 1
            save(st)
            out(f"Successfully switched over to \"{candidates[0]}\"")
            return 0
        if argv[1] == "restart":
            member = next((a for a in argv[2:]
                           if not a.startswith("-") and "-" in a
                           and a != st["cluster"] + "-ha"), None)
            (STATE_DIR / "restarts.log").open("a").write(
                json.dumps({"member": member or "cluster", "t": now()}) + "\n")
            out(f"Success: restart for member {member or '(all)'}")
            return 0
    if argv[0] == "pgbackrest" or (argv[0] == "bash" and "pgbackrest" in joined):
        if "info" in argv:
            out(pgbackrest_info_json(st) if "--output=json" in argv
                else pgbackrest_info(st))
            return 0
        if "backup" in argv:
            if backup_running(st):
                sys.stderr.write(
                    "ERROR: [050]: unable to acquire lock on file "
                    "'/tmp/pgbackrest/db-backup.lock': Resource temporarily "
                    "unavailable\n")
                return 50
            btype = next((a.split("=", 1)[1] for a in argv
                          if a.startswith("--type=")), "incr")
            st["backup_until"] = now() + BACKUP_S
            save(st)
            time.sleep(BACKUP_S)
            st = load()
            label = time.strftime("%Y%m%d-%H%M%S") + \
                {"full": "F", "diff": "D", "incr": "I"}[btype]
            st["backups"].append({"label": label, "type": btype})
            st["backup_until"] = 0
            save(st)
            out(f"INFO: {btype} backup label = {label}")
            return 0
    if argv[0] == "psql" or "psql" in joined.split():
        sql = ""
        for i, a in enumerate(argv):
            if a == "-c" and i + 1 < len(argv):
                sql = argv[i + 1]
        if st["killed_at"] and now() < st["killed_at"] + RESTART_S \
                and pod == st["leader"]:
            sys.stderr.write("psql: error: connection to server failed: "
                             "Connection refused\n")
            return 2
        low = " ".join(sql.split()).lower()
        if low.startswith("create extension"):
            ext = low.replace(";", "").split()[-1]
            exts = st.setdefault("extensions", ["pgaudit"])
            if ext not in exts:
                exts.append(ext)
            save(st)
            return 0
        if "from pg_stat_monitor" in low or "from pg_stat_statements" in low:
            view = "pg_stat_monitor" if "pg_stat_monitor" in low \
                else "pg_stat_statements"
            if view in st.get("extensions", []):
                out("37")
                return 0
            sys.stderr.write(f'ERROR:  relation "{view}" does not exist\n')
            return 1
        if "pg_is_in_recovery" in low:
            out("f" if pod == st["leader"] else "t")
            return 0
        out(run_sql(st, sql))
        return 0
    if argv[0] == "bash" and "kill" in joined and "postmaster.pid" in joined:
        st["killed_at"] = now()
        save(st)
        return 0
    if argv[0] == "grep" and "/etc/pgbouncer" in joined:
        gl = (st["cr"]["spec"].get("proxy", {}).get("pgBouncer", {})
              .get("config", {}).get("global", {}))
        hits = [f"{k} = {v}" for k, v in sorted(gl.items())]
        if hits:
            out("\n".join(hits))
            return 0
        return 1
    if argv[0] == "grep" or (argv[0] == "bash" and "grep" in joined
                             and "pgbackrest" in joined):
        gl = st["cr"]["spec"]["backups"]["pgbackrest"].get("global", {})
        hits = [f"/etc/pgbackrest/conf.d/~postgres-operator_server.conf:{k}={v}"
                for k, v in sorted(gl.items())
                if k in ("process-max", "archive-async", "spool-path")]
        if hits:
            out("\n".join(hits))
            return 0
        return 1
    if "archive_status" in joined:                # queue-depth sampler
        out(str(archive_queue_depth(st)))
        return 0
    if argv[0] == "df":
        out("Filesystem 1024-blocks Used Available Capacity Mounted on")
        out("/dev/sda1 104857600 39845888 65011712 38% /pgdata")
        return 0
    if argv[0] == "du" and "pgdata" in joined:
        out("38G /pgdata")
        return 0
    sys.stderr.write(f"fake kubectl exec: unhandled command: {joined}\n")
    return 1


def diskstats_text():
    """Node diskstats with counters advancing at DEV_IOPS (reads 60/40 writes),
    ~16KB per IO, utilization DEV_UTIL%."""
    t = now()
    reads = int(t * DEV_IOPS * 0.6)
    writes = int(t * DEV_IOPS * 0.4)
    rd_sec, wr_sec = reads * 32, writes * 32
    io_ms = int(t * DEV_UTIL * 10)          # DEV_UTIL% of wall-clock, in ms
    wt_ms = int(t * DEV_UTIL * 40)          # ~4 in-flight at full util
    maj, minor = DEV_MAJMIN.split(":")
    lines = [
        f"   7       0 loop0 55 0 2288 10 0 0 0 0 0 20 10 0 0 0 0",
        f" {maj}       {minor} nvme1n1 {reads} 12 {rd_sec} {reads // 3} "
        f"{writes} 40 {wr_sec} {writes // 2} 2 {io_ms} {wt_ms} 0 0 0",
        f" 259       0 nvme0n1 9000 5 720000 4000 8000 10 640000 6000 0 8000 10000 0 0 0",
    ]
    return "\n".join(lines)


MOUNTINFO = (f"469 432 {DEV_MAJMIN} / /pgdata rw,relatime - ext4 "
             "/dev/nvme1n1 rw\n"
             "470 432 0:123 / /tmp rw - tmpfs tmpfs rw\n")


def handle_pmm_logs(st, pod):
    """pmm-client sidecar logs: the QAN agent line appears once the pod has
    rolled AND the paired extension exists (FAKE_KUBE_NO_QAN suppresses it)."""
    pmm = st["cr"]["spec"].get("pmm") or {}
    qs = pmm.get("querySource", "pgstatmonitor")
    ext = {"pgstatmonitor": "pg_stat_monitor",
           "pgstatements": "pg_stat_statements"}.get(qs, "pg_stat_monitor")
    ts = time.strftime("%Y-%m-%dT%H:%M:%S") + ",000Z"
    out(f"{ts} INFO pmm-agent: connected to {pmm.get('serverHost', '')}")
    if (pmm_rolled(st, pod) and ext in st.get("extensions", [])
            and not os.environ.get("FAKE_KUBE_NO_QAN")):
        out(f"{ts} INFO qan_postgresql_{qs}_agent: sending 4 metrics buckets")
    return 0


def handle_logs(st, pod, follow):
    if "pgbouncer" in pod:
        lines = ["pgbouncer: LOG stats: 60 xacts/s"]
        if st["killed_at"]:
            lines = [
                "pgbouncer: LOG S-0x1: db/user@10.244.0.20:5432 closing because: "
                "server conn crashed? (age=42s)",
                "pgbouncer: WARNING S-0x2: db/user@10.244.0.20:5432 "
                "login failed: FATAL: the database system is starting up",
                "pgbouncer: LOG S-0x2: retrying in 15 s (server_login_retry)",
            ]
    else:
        lines = [f"INFO: no action. I am ({pod}), the leader with the lock"
                 if pod == st["leader"] else
                 f"INFO: no action. I am ({pod}), a secondary, and following "
                 f"a leader ({st['leader']})"]
        if st["killed_at"] and pod == st["leader"]:
            lines = ["WARNING: Postgres is not running.",
                     "INFO: starting as readonly because i had the session lock",
                     "INFO: establishing a new patroni heartbeat connection to postgres",
                     f"INFO: no action. I am ({pod}), the leader with the lock"]
    for ln in lines:
        out(time.strftime("%Y-%m-%dT%H:%M:%S") + f",000Z {ln}")
    if follow:
        # keep the stream open briefly, emitting heartbeats; scenario runners
        # kill us (process group) when capture stops.
        deadline = now() + float(os.environ.get("FAKE_KUBE_LOG_FOLLOW_S", "30"))
        while now() < deadline:
            time.sleep(0.5)
            emitted = load()
            if emitted["killed_at"] and pod == emitted["leader"] \
                    and now() < emitted["killed_at"] + RESTART_S:
                out(time.strftime("%Y-%m-%dT%H:%M:%S") +
                    ",000Z WARNING: Postgres is not running.")
            sys.stdout.flush()
    return 0


def main():
    args = sys.argv[1:]
    # strip global flags
    cleaned = []
    i = 0
    while i < len(args):
        if args[i] in ("--context", "-n", "--namespace"):
            i += 2
            continue
        cleaned.append(args[i])
        i += 1
    args = cleaned
    if not args:
        return 2
    # FAKE_KUBE_AUTH_FAIL=1: every API-touching command fails like an expired
    # token / bad exec-credential kubeconfig (the DOKS doctl failure mode);
    # client-only commands still work, exactly like real kubectl.
    if os.environ.get("FAKE_KUBE_AUTH_FAIL") and args[0] not in ("version", "config"):
        print("error: You must be logged in to the server (the server has asked "
              "for the client to provide credentials)", file=sys.stderr)
        return 1
    st = load()
    maybe_elect(st)
    settle_manual(st)
    st = load()
    cmd = args[0]

    if cmd == "version":
        out(json.dumps({"clientVersion": {"gitVersion": "v1.31.0-fake"}}))
        return 0
    if cmd == "config":
        if "current-context" in args:
            out("do-nyc1-fake")
            return 0
        if "view" in args:
            out("https://fake-k8s.example.com:6443")
            return 0
    if cmd == "auth":
        out("yes")
        return 0
    if cmd == "get":
        kind = args[1] if len(args) > 1 else ""
        rest = args[2:]
        o_json = "-o" in rest and "json" in rest or "json" in " ".join(rest)
        o_name = "-o" in rest and "name" in rest
        if kind in ("ns", "namespaces"):
            names = ["default", "kube-system", "percona"]
            out("\n".join(f"namespace/{n}" for n in names) if o_name
                else "\n".join(names))
            return 0
        if kind in ("pods", "pod"):
            named = [a for a in rest if not a.startswith("-") and a != "json"]
            if named and not o_name:
                name = named[0]
                extra = st.get("extra_pods", {}).get(name)
                if extra is not None:
                    out(json.dumps({
                        "metadata": {"name": name, "uid": f"uid-{name}",
                                     "labels": {"app": "pgbench-harness-device-probe"}},
                        "spec": {"nodeName": extra["node"],
                                 "containers": [{"name": "fileio",
                                                 "image": extra["image"]}]},
                        "status": {"phase": "Running",
                                   "containerStatuses": [{"name": "fileio",
                                                          "ready": True,
                                                          "restartCount": 0}]}}))
                    return 0
                if not pod_alive(st, name):
                    sys.stderr.write(f'Error from server (NotFound): pods "{name}" not found\n')
                    return 1
                is_inst = any(i["name"] == name for i in st["instances"])
                out(json.dumps(pod_json(st, name, "instance" if is_inst else "pgbouncer")))
                return 0
            items = all_pods(st)
            if o_name:
                out("\n".join(f"pod/{p['metadata']['name']}" for p in items))
                return 0
            out(json.dumps({"items": items}))
            return 0
        if kind in (CR_KIND, "perconapgcluster", "postgrescluster",
                    "perconapgclusters", "postgresclusters"):
            if kind.rstrip("s") != CR_KIND and kind != CR_KIND:
                sys.stderr.write(f'error: the server doesn\'t have a resource type "{kind}"\n')
                return 1
            named = [a for a in rest if not a.startswith("-")
                     and a not in ("json", "yaml")]
            if "-o" in rest and "yaml" in rest:
                # cheap YAML render (only used for snapshots — kept raw anyway)
