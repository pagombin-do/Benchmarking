def load():
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    if STATE.exists():
        try:
            return json.loads(STATE.read_text())
        except ValueError:
            pass
    st = default_state()
    save(st)
    return st


def save(st):
    tmp = STATE.with_suffix(".tmp")
    tmp.write_text(json.dumps(st, indent=1))
    os.replace(tmp, STATE)


def now():
    return time.time()


def sync_instances(st):
    """Mirror spec.instances[0].replicas into the running pod list —
    grow with fresh member names, shrink from the tail (never the leader)."""
    sets = st["cr"]["spec"].get("instances") or []
    want = int((sets[0] or {}).get("replicas", len(st["instances"]))) if sets \
        else len(st["instances"])
    cur = len(st["instances"])
    suffixes = ["mnop", "qrst", "uvwx", "yz01", "2345"]
    while len(st["instances"]) < want:
        i = len(st["instances"])
        name = f"{st['cluster']}-instance1-{suffixes[i % len(suffixes)]}-0"
        st["instances"].append({"name": name, "node": f"node-{i}",
                                "ip": f"10.244.0.{20 + i}"})
    while len(st["instances"]) > want:
        tail = st["instances"][-1]
        if tail["name"] == st["leader"]:
            break
        st["instances"].pop()
    if cur != want:
        st["deleted"] = {k: v for k, v in st["deleted"].items()
                         if any(i["name"] == k for i in st["instances"])}


def pod_alive(st, name):
    del_at = st["deleted"].get(name, 0)
    if del_at and now() < del_at + RECREATE_S:
        return False
    inst = next((i for i in st["instances"] if i["name"] == name), None)
    if inst and inst["node"] in st["lost_nodes"]:
        return False
    return True


def leader_state(st):
    """Patroni state string for the current leader (time-driven recovery)."""
    if st["killed_at"] and now() < st["killed_at"] + RESTART_S:
        return "starting"
    return "running"


def maybe_elect(st):
    """Complete a pending election (node loss) once ELECT_S has passed."""
    if st.get("elect_at") and now() >= st["elect_at"]:
        candidates = [i["name"] for i in st["instances"]
                      if i["name"] != st["leader"] and pod_alive(st, i["name"])]
        if candidates:
            st["leader"] = candidates[0]
            st["tl"] += 1
        st["elect_at"] = 0
        save(st)


def out(s=""):
    sys.stdout.write(s if s.endswith("\n") or not s else s + "\n")


def pmm_rolled(st, name):
    """Has this pod been recreated with the PMM sidecar yet? (time-staged)"""
    pmm = st["cr"]["spec"].get("pmm") or {}
    if not pmm.get("enabled"):
        return False
    return now() >= st.get("pmm_roll", {}).get(name, 0)


def pmm_client_container(st):
    """The sidecar the operator injects, with the env the verifier inspects
    (PMM3 markers: --query-source in the prerun, non-/pmm2/ config path)."""
    pmm = st["cr"]["spec"].get("pmm") or {}
    qs = pmm.get("querySource", "pgstatmonitor")
    return {"name": "pmm-client", "image": pmm.get("image", ""),
            "envFrom": [{"secretRef": {"name": pmm.get("secret", "")}}],
            "env": [
                {"name": "PMM_AGENT_SERVER_ADDRESS",
                 "value": str(pmm.get("serverHost", ""))},
                {"name": "PMM_AGENT_CONFIG_FILE",
                 "value": "/usr/local/percona/pmm/config/pmm-agent.yaml"},
                {"name": "PMM_AGENT_PRERUN_SCRIPT",
                 "value": "pmm-admin status --wait=10s; pmm-admin add postgresql "
                          f"--skip-connection-check --query-source={qs} "
                          "--tls-skip-verify $(hostname)"},
            ]}


def pod_json(st, name, kind):
    alive = pod_alive(st, name)
    rolled = False
    if kind == "instance":
        containers = [{"name": "database"}, {"name": "replication-cert-copy"},
                      {"name": "pgbackrest"}, {"name": "pgbackrest-config"}]
        rolled = pmm_rolled(st, name)
        if rolled:
            containers.append(pmm_client_container(st))
        labels = {"postgres-operator.crunchydata.com/cluster": st["cluster"],
                  "postgres-operator.crunchydata.com/instance-set": "instance1"}
        if not os.environ.get("FAKE_KUBE_NO_ROLE_LABEL"):
            labels["postgres-operator.crunchydata.com/role"] = \
                "master" if name == st["leader"] else "replica"
    else:
        containers = [{"name": "pgbouncer"}, {"name": "pgbouncer-config"}]
        labels = {"postgres-operator.crunchydata.com/cluster": st["cluster"],
                  "postgres-operator.crunchydata.com/role": "pgbouncer"}
    inst = next((i for i in st["instances"] if i["name"] == name), None)
    node = inst["node"] if inst else "node-9"
    ip = inst["ip"] if inst else "10.244.1.9"
    starting = (kind == "instance" and name == st["leader"]
                and leader_state(st) == "starting")
    ready = alive and not starting
    # UID changes when the pod is recreated: the PMM roll and every delete.
    uid = f"uid-{name}-{'pmm' if rolled else 'base'}-{int(st['deleted'].get(name, 0))}"
    volumes = ([{"name": "postgres-data",
                 "persistentVolumeClaim": {"claimName": f"{name}-pgdata"}}]
               if kind == "instance" else [])
    return {
        "metadata": {"name": name, "namespace": "percona", "uid": uid,
                     "labels": labels},
        "spec": {"nodeName": node, "containers": containers,
                 "volumes": volumes},
        "status": {"phase": "Running" if alive else "Pending", "podIP": ip,
                   "containerStatuses": [{"name": c["name"], "ready": ready,
                                          "restartCount": 0}
                                         for c in containers]},
    }


def all_pods(st):
    items = []
    for i in st["instances"]:
        if pod_alive(st, i["name"]):
            items.append(pod_json(st, i["name"], "instance"))
    for name in st["pgbouncer"]:
        items.append(pod_json(st, name, "pgbouncer"))
    return items


def patronictl_list(st):
    maybe_elect(st)
    members = []
    for i in st["instances"]:
        if not pod_alive(st, i["name"]):
            continue
        is_leader = i["name"] == st["leader"]
        m = {"Cluster": f"{st['cluster']}-ha", "Member": i["name"], "Host": i["ip"],
             "Role": "Leader" if is_leader else "Replica",
             "State": leader_state(st) if is_leader else "streaming",
             "TL": st["tl"]}
        if not is_leader:
            m["Lag in MB"] = 0
        members.append(m)
    return json.dumps(members)


def backup_running(st):
    return (os.environ.get("FAKE_KUBE_BACKUP_LOCKED") == "1"
            or now() < st.get("backup_until", 0)
            or (st.get("manual_started", 0)
                and now() < st["manual_started"] + BACKUP_S))


def settle_manual(st):
    """Complete an operator-path (manual annotation) backup once its window ends."""
    if st.get("manual_started", 0) and now() >= st["manual_started"] + BACKUP_S:
        btype = st.get("manual_type", "incr")
        label = time.strftime("%Y%m%d-%H%M%S") + \
            {"full": "F", "diff": "D", "incr": "I"}.get(btype, "I")
        st["backups"].append({"label": label, "type": btype})
        st["manual_started"] = 0
        save(st)


def pgbackrest_info(st):
    status = ("ok (backup/expire running)" if backup_running(st) else "ok")
    lines = [f"stanza: db\n    status: {status}\n"
             "    cipher: none\n\n    db (current)\n"
             "        wal archive min/max (18): 000000050000000000000010/0000000500000000000000FF\n"]
    for b in st["backups"][-4:]:
        lines.append(
            f"        {b['type']} backup: {b['label']}\n"
            f"            timestamp start/stop: 2026-07-07 00:00:04 / 2026-07-07 00:29:59\n"
            f"            wal start/stop: 000000050000000000000012 / 000000050000000000000034\n"
            f"            database size: 12.2GB, database backup size: 12.2GB\n"
            f"            repo1: backup set size: 1.9GB, backup size: 1.9GB\n")
    return "\n".join(lines)


def pgbackrest_info_json(st):
    # Dynamic timestamps: newest backup finished an hour ago (healthy for the
    # backup-staleness heuristic), each older one a day further back.
    n = len(st["backups"])
    return json.dumps([{
        "name": "db",
        "status": {"code": 0,
                   "message": "ok (backup/expire running)" if backup_running(st) else "ok"},
        "backup": [{"label": b["label"], "type": b["type"],
                    "info": {"size": 13100000000, "delta": 13100000000,
                             "repository": {"size": 2040000000, "delta": 2040000000}},
                    "timestamp": {"start": int(now()) - (n - 1 - i) * 86400 - 5400,
                                  "stop": int(now()) - (n - 1 - i) * 86400 - 3600}}
                   for i, b in enumerate(st["backups"])],
    }])


