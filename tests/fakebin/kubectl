                pi = args.index("--patch")
            except ValueError:
                return 2
        patch = json.loads(args[pi + 1])

        if isinstance(patch, list):
            # kubectl patch --type json: replace/add on a /-separated path.
            for op in patch:
                path = [seg for seg in op.get("path", "").split("/") if seg]
                cur = st["cr"]
                for seg in path[:-1]:
                    cur = cur[int(seg)] if isinstance(cur, list) else \
                        cur.setdefault(seg, {})
                leaf = path[-1]
                if isinstance(cur, list):
                    cur[int(leaf)] = op.get("value")
                else:
                    cur[leaf] = op.get("value")
            sync_instances(st)
            st["cr"]["metadata"]["generation"] += 1
            save(st)
            (STATE_DIR / "patches.log").open("a").write(json.dumps(patch) + "\n")
            out(f"{CR_KIND}.pgv2.percona.com/{st['cluster']} patched")
            return 0

        def deep_merge(dst, src):
            for k, v in src.items():
                if v is None:
                    dst.pop(k, None)
                elif isinstance(v, dict) and isinstance(dst.get(k), dict):
                    deep_merge(dst[k], v)
                else:
                    dst[k] = v
        deep_merge(st["cr"], patch)
        if ((patch.get("spec") or {}).get("pmm") or {}).get("enabled"):
            # the operator rolls the instance pods one at a time
            st["pmm_roll"] = {i["name"]: now() + ROLL_S * (k + 1)
                              for k, i in enumerate(st["instances"])}
        pend = os.environ.get("FAKE_KUBE_PENDING_PARAMS", "")
        touched = (patch.get("spec", {}).get("patroni", {})
                   .get("dynamicConfiguration", {}).get("postgresql", {})
                   .get("parameters", {}) or {})
        st["pending_restart"] = [p for p in touched if p in pend.split(",")]
        st["cr"]["metadata"]["generation"] += 1
        save(st)
        (STATE_DIR / "patches.log").open("a").write(json.dumps(patch) + "\n")
        out(f"{CR_KIND}.pgv2.percona.com/{st['cluster']} patched")
        return 0
    if cmd == "annotate":
        if any("pgbackrest-backup" in a for a in args):
            st["manual_started"] = now()
            st["manual_type"] = (st["cr"]["spec"]["backups"]["pgbackrest"]
                                 .get("manual", {}) or {})
            opts = st["manual_type"].get("options", []) if isinstance(
                st["manual_type"], dict) else []
            st["manual_type"] = next((o.split("=", 1)[1] for o in opts
                                      if o.startswith("--type=")), "incr")
            st["manual_done_job"] = f"{st['cluster']}-backup-abcd"
            save(st)
        out("annotated")
        return 0
    if cmd == "delete":
        if args[1] in ("secret", "secrets"):
            name = args[2]
            if st.get("pmm_secret") == name:
                st["pmm_secret"] = ""
                save(st)
                out(f'secret "{name}" deleted')
                return 0
            sys.stderr.write(f'Error from server (NotFound): secrets "{name}" not found\n')
            return 1
        if args[1] in ("pod", "pods"):
            name = args[2]
            if name in st.get("extra_pods", {}):
                del st["extra_pods"][name]
                save(st)
                out(f'pod "{name}" deleted')
                return 0
            st["deleted"][name] = now()
            if name == st["leader"]:
                if os.environ.get("FAKE_KUBE_C1_ELECT") == "1":
                    st["elect_at"] = now() + ELECT_S
                else:
                    st["killed_at"] = now()   # restart-in-place write outage
            save(st)
            out(f'pod "{name}" force deleted')
            return 0
        if args[1] in ("node", "nodes"):
            node = args[2]
            st["lost_nodes"].append(node)
            leader_inst = next((i for i in st["instances"]
                                if i["name"] == st["leader"]), None)
            if leader_inst and leader_inst["node"] == node:
                st["elect_at"] = now() + ELECT_S
            save(st)
            out(f'node "{node}" deleted')
            return 0
    if cmd in ("cordon", "drain"):
        out(f"node/{args[1]} cordoned")
        return 0
    if cmd == "logs":
        follow = "-f" in args or "--follow" in args
        pod = next(a for a in args[1:] if not a.startswith("-")
                   and a not in ("database", "pgbouncer", "pgbackrest",
                                 "pmm-client"))
        if "pmm-client" in args:
            return handle_pmm_logs(st, pod)
        return handle_logs(st, pod, follow)
    if cmd == "exec":
        try:
            dash = args.index("--")
        except ValueError:
            return 2
        pod = next(a for a in args[1:dash] if not a.startswith("-")
                   and a not in ("database", "pgbouncer", "pgbackrest"))
        if not pod_alive(st, pod):
            sys.stderr.write(f'Error from server (NotFound): pods "{pod}" not found\n')
            return 1
        return handle_exec(st, pod, args[dash + 1:])
    if cmd == "top":
        out("NAME CPU(cores) MEMORY(bytes)")
        for i in st["instances"]:
            out(f"{i['name']} {'890m' if i['name'] == st['leader'] else '120m'} 2048Mi")
        return 0
    sys.stderr.write(f"fake kubectl: unhandled: {' '.join(args[:4])}\n")
    return 1


if __name__ == "__main__":
    sys.exit(main())
