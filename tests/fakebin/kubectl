                         "csi": {"driver": "dobs.csi.digitalocean.com",
                                 "volumeHandle": "e2fa2c55-fake-volume-id",
                                 "volumeAttributes": (
                                     {"iopsPerGB": os.environ["FAKE_KUBE_SC_IOPS"]}
                                     if os.environ.get("FAKE_KUBE_SC_IOPS")
