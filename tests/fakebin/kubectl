                return 0
            if named:
                if named[0] != st["cluster"]:
                    sys.stderr.write(f'Error from server (NotFound): {named[0]} not found\n')
                    return 1
                out(json.dumps(st["cr"]))
                return 0
            out(json.dumps({"items": [st["cr"]]}))
            return 0
        if kind in ("pvc", "persistentvolumeclaim", "persistentvolumeclaims"):
            name = args[2]
            out(json.dumps({
                "metadata": {"name": name,
                             "annotations": {"volume.kubernetes.io/storage-provisioner":
                                             "dobs.csi.digitalocean.com"}},
                "spec": {"storageClassName": os.environ.get("FAKE_KUBE_SC",
                                                            "do-block-storage"),
                         "volumeName": f"pv-{name}"},
