<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Run comparison — {{ runs | map(attribute="label") | join(" vs ") }}</title>
<style>{% include "base.css.j2" %}</style>
</head>
<body>

<div class="banner">
  <h1>Run comparison</h1>
  <div class="runid">{{ runs | map(attribute="run_id") | join("  ·  ") }}</div>
  <div class="crumbs">
    {% for r in runs %}<span class="crumb">{{ r.label }} ({{ r.edition }} · {{ r.tshirt_size }})</span>{% endfor %}
    <span class="crumb">generated {{ generated_utc }} UTC</span>
  </div>
</div>

<main>
<div class="card soft">
  <table style="margin:0">
    <tr><th>Run</th><th>Run id</th><th>Edition</th><th>Size</th><th>Status</th><th>Workload</th></tr>
    {% for r in runs %}
    <tr>
      <td><b>{{ r.label }}</b></td>
      <td style="text-align:left">{{ r.run_id }}</td>
      <td>{{ r.edition }}</td>
      <td>{{ r.tshirt_size }}</td>
      <td><span class="badge {{ r.status }}">{{ r.status }}</span></td>
      <td style="text-align:left">{{ r.workload.type }} (tables {{ r.workload.tables }}{% if r.workload.scale %}, scale {{ r.workload.scale }}{% endif %}{% if r.workload.table_size %}, table_size {{ "{:,}".format(r.workload.table_size) }}{% endif %})</td>
    </tr>
    {% endfor %}
  </table>
</div>

<h2><span class="secno">1</span>Throughput</h2>
{% if charts.qps %}<div class="chart"><img alt="QPS comparison" src="{{ charts.qps }}"></div>
{% else %}<p class="subtle">No successful levels to chart.</p>{% endif %}

<h2><span class="secno">2</span>Latency (p99)</h2>
{% if charts.p99 %}<div class="chart"><img alt="p99 latency comparison" src="{{ charts.p99 }}"></div>
{% else %}<p class="subtle">No p99 data to chart.</p>{% endif %}

<h2><span class="secno">3</span>Headline side-by-side</h2>
<p class="subtle">Union of thread ladders; “—” marks levels a run did not execute or that failed.</p>
<table>
  <tr>
    <th rowspan="2">Threads</th>
    {% for r in runs %}<th colspan="2">{{ r.label }}</th>{% endfor %}
    {% if table.with_delta %}<th rowspan="2">Δ QPS %</th>{% endif %}
  </tr>
  <tr>
    {% for r in runs %}<th>QPS</th><th>p99 (ms)</th>{% endfor %}
  </tr>
  {% for row in table.rows %}
  <tr>
    <td>{{ row.threads }}</td>
    {% for c in row.cells %}
    <td>{{ "{:,.0f}".format(c.qps) if c.qps is not none else "—" }}</td>
    <td>{{ "%.2f" | format(c.p99) if c.p99 is not none else "—" }}</td>
    {% endfor %}
    {% if table.with_delta %}
    <td>{{ "%+.1f" | format(row.delta_pct) if row.delta_pct is not none else "—" }}</td>
    {% endif %}
  </tr>
  {% endfor %}
</table>
{% if table.with_delta %}<p class="subtle">Δ QPS % = second run vs first run at the same thread level.</p>{% endif %}

<h2><span class="secno">4</span>Settings diff</h2>
{% if diff %}
<p class="subtle">Only pg_settings rows that differ between runs are shown.</p>
<table>
  <tr><th>Setting</th>{% for r in runs %}<th>{{ r.label }}</th>{% endfor %}</tr>
  {% for d in diff %}
  <tr><td>{{ d.name }}</td>{% for v in d.vals %}<td>{{ v }}</td>{% endfor %}</tr>
  {% endfor %}
</table>
{% elif any_settings %}
<p>No differing pg_settings between these runs.</p>
{% else %}
<p class="subtle">No pg_settings captures available to diff.</p>
{% endif %}
</main>

<footer>Generated by {{ harness }}.</footer>
</body>
</html>
