<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Soak comparison — {{ runs | length }} runs</title>
<style>{% include "base.css.j2" %}</style>
</head>
<body>

<div class="banner">
  <h1>Soak comparison — {{ runs | length }} runs</h1>
  <div class="crumbs">{% for r in runs %}<span class="crumb">{{ r.display }}</span>{% endfor %}</div>
</div>

<main>
<div class="toc">
  <a href="#headline">Headline</a><a href="#env">Environment</a>
  <a href="#fairness">Comparability</a><a href="#charts">Time series</a>
  <a href="#keysettings">Key settings</a><a href="#diff">Settings diff</a>
</div>

{% if winner %}
<div class="note" style="font-size:15px"><b>Highest median TPS:</b> {{ winner.display }}
  ({{ winner.median_tps | round(1) }} TPS{% if winner.margin_pct is not none %}, +{{ winner.margin_pct | round(1) }}% over the runner-up{% endif %}).</div>
{% endif %}
{% if deltas and deltas.median_tps is not none %}
<div class="note"><b>{{ runs[1].display }}</b> vs <b>{{ runs[0].display }}</b>:
  median TPS {{ "%+.1f" | format(deltas.median_tps) }}%{% if deltas.p99 is not none %},
  p99 latency {{ "%+.1f" | format(deltas.p99) }}%{% endif %}.</div>
{% endif %}

{% if not fairness.fair %}
<div class="warnbox" style="font-size:14px">
  <b>⚠ Not an apples-to-apples comparison:</b>
  {{ fairness.mismatches | map(attribute="name") | join(", ") }} differ —
  see the <a href="#fairness">comparability check</a> before quoting deltas.
</div>
{% endif %}

<h2 id="headline"><span class="secno">1</span>Headline metrics</h2>
<div class="table-wrap">
<table>
  <thead><tr>
    <th>Run</th><th class="num">Threads</th><th class="num">Median TPS</th><th class="num">Peak TPS</th>
    <th class="num">CoV %</th><th class="num">p50</th><th class="num">p95</th><th class="num">p99</th>
    <th class="num">Coverage</th><th class="num">Longest outage</th>
    <th class="num">Events</th><th class="num">Detected</th><th>Status</th>
  </tr></thead>
  <tbody>
  {% for k in kpis %}
  <tr>
    <td>{{ k.display }}</td>
    <td class="num">{{ k.threads if k.threads is not none else "—" }}</td>
    <td class="num">{{ k.median_tps | round(1) if k.median_tps is not none else "—" }}</td>
    <td class="num">{{ k.peak_tps | round(1) if k.peak_tps is not none else "—" }}</td>
    <td class="num">{{ k.cov_pct if k.cov_pct is not none else "—" }}</td>
    <td class="num">{{ k.p50 if k.p50 is not none else "—" }}</td>
    <td class="num">{{ k.p95 if k.p95 is not none else "—" }}</td>
    <td class="num">{{ k.p99 if k.p99 is not none else "—" }}</td>
    <td class="num">{{ k.coverage_pct if k.coverage_pct is not none else "—" }}%</td>
    <td class="num">{{ k.longest_outage_s if k.longest_outage_s is not none else "—" }}s</td>
    <td class="num">{{ k.events }}</td>
    <td class="num">{{ k.detected }}</td>
    <td><span class="badge {{ k.status }}">{{ k.status }}</span></td>
  </tr>
  {% endfor %}
  </tbody>
</table>
</div>
<p class="subtle">Latency columns are whole-run figures (p50/p95/p99 from each soak's end-of-run histogram). "Detected" counts auto-detected, unconfirmed anomalies.</p>

{% with part="context", secno_env="2", secno_fair="3" %}{% include "compare_common.html.j2" %}{% endwith %}

<h2 id="charts"><span class="secno">4</span>Time series (overlaid)</h2>
{% if chart %}
<div class="chart"><img alt="Throughput over time (overlaid)" src="{{ chart }}">
  <div class="cap">Per-second TPS for each soak, overlaid on a shared elapsed-time axis (decimated for legibility).</div>
</div>
{% endif %}
{% if chart_lat %}
<div class="chart"><img alt="p99 latency over time (overlaid)" src="{{ chart_lat }}">
  <div class="cap">Per-second p99 latency — throughput parity with worse tail latency is not parity.</div>
</div>
{% endif %}
{% if chart_err %}
<div class="chart"><img alt="Errors/s over time (overlaid)" src="{{ chart_err }}">
  <div class="cap">Errors per second — a flat zero line is part of the result.</div>
</div>
{% endif %}
{% if not chart and not chart_lat %}<p class="subtle">No per-second series available to overlay.</p>{% endif %}

{% with part="settings", secno_key="5" %}{% include "compare_common.html.j2" %}{% endwith %}

<h2 id="diff"><span class="secno">6</span>Settings diff</h2>
{% if diff %}
<div class="table-wrap">
<table>
  <thead><tr><th>Setting</th>{% for r in runs %}<th>{{ r.display }}</th>{% endfor %}</tr></thead>
  <tbody>
  {% for d in diff %}
  <tr><td class="mono">{{ d.name }}{% if d.is_key %} <span class="subtle">(key)</span>{% endif %}</td>
    {% for v in d.vals %}<td class="mono">{{ v }}</td>{% endfor %}</tr>
  {% endfor %}
  </tbody>
</table>
</div>
{% elif any_settings %}
<p class="subtle">No pg_settings differences among these runs.</p>
{% endif %}
</main>

<footer>Generated by {{ harness }} · {{ generated_utc }}.</footer>
</body>
</html>
