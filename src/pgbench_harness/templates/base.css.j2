{# Shared CSS for run and compare reports. Inlined into a <style> tag. #}
:root {
  --brand: #0061eb; --brand-dark: #0b2d5c; --ink: #16202b; --muted: #5b6573;
  --line: #dde3ea; --bg-soft: #f6f8fb; --warn-bg: #fdf3d7; --fail-bg: #fdeae8;
  color-scheme: light;
}
* { box-sizing: border-box; }
html { background: #eef1f5; overflow-y: auto;}
body {
  background: #ffffff; color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  font-size: 15px; line-height: 1.6;
  max-width: 1320px; margin: 24px auto; padding: 0 0 72px;
  border-radius: 14px; box-shadow: 0 2px 18px rgba(11, 45, 92, .10);
  overflow: hidden;
}
.banner {
  background: linear-gradient(120deg, var(--brand-dark) 0%, #114a9e 55%, var(--brand) 100%);
  color: #fff; padding: 40px 56px 34px;
}
.banner h1 { font-size: 30px; margin: 0 0 4px; letter-spacing: -.3px; }
.banner .runid { font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
  font-size: 13px; opacity: .75; }
.banner .crumbs { margin-top: 14px; display: flex; flex-wrap: wrap; gap: 8px; }
.crumb { background: rgba(255,255,255,.14); border: 1px solid rgba(255,255,255,.22);
  border-radius: 999px; padding: 3px 14px; font-size: 13px; }
main { padding: 0 56px; }
h2 { font-size: 21px; margin: 56px 0 14px; padding-left: 14px;
  border-left: 5px solid var(--brand); letter-spacing: -.2px; }
h2 .secno { color: var(--muted); font-weight: 600; margin-right: 6px; }
h3 { font-size: 16px; margin: 26px 0 10px; color: #2b3440; }
.subtle { color: var(--muted); }
.toc { display: flex; flex-wrap: wrap; gap: 8px; margin: 26px 0 6px; }
.toc a { text-decoration: none; color: var(--brand-dark); background: var(--bg-soft);
  border: 1px solid var(--line); border-radius: 999px; padding: 4px 14px; font-size: 13px; }
.toc a:hover { border-color: var(--brand); color: var(--brand); }
.kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  gap: 14px; margin: 26px 0 8px; }
.kpi { background: var(--bg-soft); border: 1px solid var(--line); border-radius: 12px;
  padding: 16px 18px 13px; }
.kpi .v { font-size: 26px; font-weight: 700; color: var(--brand-dark); letter-spacing: -.5px; }
.kpi .v small { font-size: 14px; font-weight: 600; color: var(--muted); }
.kpi .k { font-size: 12.5px; color: var(--muted); text-transform: uppercase;
  letter-spacing: .06em; margin-top: 2px; }
.kpi.bad .v { color: #a01b12; }
.card { border: 1px solid var(--line); border-radius: 12px; padding: 22px 26px;
  margin: 22px 0; background: #fff; }
.card.soft { background: var(--bg-soft); }
.meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 7px 32px; }
.meta-grid div { padding: 2px 0; font-size: 14.5px; }
.meta-grid b { color: #2b3440; font-weight: 600; }
.badge { display: inline-block; padding: 2px 13px; border-radius: 999px;
  font-weight: 700; font-size: 13px; letter-spacing: .02em; text-transform: uppercase; }
.badge.complete { background: #d9f2e0; color: #11602a; }
.badge.partial  { background: var(--warn-bg); color: #7a5000; }
.badge.failed, .badge.running { background: var(--fail-bg); color: #a01b12; }
table { border-collapse: collapse; width: 100%; margin: 16px 0; font-size: 14px;
  border: 1px solid var(--line); border-radius: 10px; overflow: hidden; }
th, td { border-bottom: 1px solid var(--line); padding: 9px 14px; text-align: right;
  font-variant-numeric: tabular-nums; }
th { background: var(--brand-dark); color: #fff; font-size: 12.5px; font-weight: 600;
  text-transform: uppercase; letter-spacing: .05em; }
th:first-child, td:first-child { text-align: left; }
tbody tr:nth-child(even) td { background: var(--bg-soft); }
tbody tr:hover td { background: #eaf1fb; }
td.warn { background: var(--warn-bg) !important; font-weight: 700; color: #7a5000; }
td.fail, tr.fail td { background: var(--fail-bg) !important; }
.chart { margin: 26px 0; border: 1px solid var(--line); border-radius: 12px;
  padding: 14px 14px 8px; background: #fff; }
.chart img { width: 100%; height: auto; display: block; }
pre { background: #0f1822; color: #dce6f2; border-radius: 10px;
  padding: 14px 18px; overflow-x: auto; font-size: 13px; line-height: 1.5; }
.note { background: #eaf2fd; border-left: 4px solid var(--brand);
  padding: 12px 18px; border-radius: 0 10px 10px 0; margin: 16px 0; font-size: 14px; }
.warnbox { background: var(--warn-bg); border-left: 4px solid #d99a1b;
  padding: 12px 18px; border-radius: 0 10px 10px 0; margin: 16px 0; font-size: 14px; }
details { margin: 16px 0; border: 1px solid var(--line); border-radius: 10px;
  padding: 4px 18px; background: var(--bg-soft); }
details summary { cursor: pointer; font-weight: 600; padding: 9px 0; color: var(--brand-dark); }
details[open] summary { border-bottom: 1px solid var(--line); margin-bottom: 8px; }
footer { margin: 64px 56px 28px; color: #8b95a3; font-size: 13px;
  border-top: 1px solid var(--line); padding-top: 16px; }
table.settings { table-layout: fixed; }
table.settings th:nth-child(1), table.settings td:nth-child(1) { width: 38%; }
table.settings th:nth-child(2), table.settings td:nth-child(2) { width: 30%; }
table.settings th:nth-child(3), table.settings td:nth-child(3) { width: 12%; }
table.settings th:nth-child(4), table.settings td:nth-child(4) { width: 20%; }
table.settings td { white-space: normal; overflow-wrap: anywhere; word-break: break-word; }
@media print { html { background: #fff; } body { box-shadow: none; margin: 0; } }
