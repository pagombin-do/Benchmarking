<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ manifest.label }} — {{ manifest.run_id }}</title>
<style>{% include "base.css.j2" %}</style>
</head>
<body>

{# ── 1. Header card ─────────────────────────────────────────────── #}
<div class="banner">
  <h1>{{ manifest.label }}</h1>
  <div class="runid">{{ manifest.run_id }}</div>
  <div class="crumbs">
    <span class="crumb">{{ manifest.edition | title }} Edition</span>
    <span class="crumb">{{ manifest.tshirt_size }}</span>
    <span class="crumb">{{ spec.workload.type }}{% if spec.workload.type == "tpcc" %} · scale {{ spec.workload.scale }}{% else %} · {{ "{:,}".format(spec.workload.table_size) }} rows/table{% endif %} · {{ spec.workload.tables }} tables</span>
    <span class="crumb">{{ manifest.created_utc }} UTC</span>
    <span class="crumb">PostgreSQL {{ env.server_version | replace("PostgreSQL ", "") | truncate(40, true) }}</span>
  </div>
</div>

<main>
<div class="toc">
  <a href="#overview">Overview</a><a href="#headline">Headline results</a>
  <a href="#throughput">Throughput</a><a href="#latency">Latency</a>
  <a href="#stability">Stability</a><a href="#errors">Errors &amp; limits</a>
  <a href="#config">Configuration</a>
</div>

{% if kpis %}
<div class="kpis">
  <div class="kpi"><div class="v">{{ "{:,.0f}".format(kpis.peak_qps) }}</div>
    <div class="k">Peak QPS · @ {{ kpis.peak_threads }} threads</div></div>
  <div class="kpi"><div class="v">{{ "{:,.0f}".format(kpis.peak_tps) }}</div>
    <div class="k">Peak TPS</div></div>
  <div class="kpi"><div class="v">{% if kpis.p99_at_peak is not none %}{{ "%.1f" | format(kpis.p99_at_peak) }}<small> ms</small>{% else %}—{% endif %}</div>
    <div class="k">p99 latency at peak</div></div>
  <div class="kpi {% if kpis.failed_levels or kpis.total_errors %}bad{% endif %}">
    <div class="v">{{ kpis.failed_levels }} / {{ "{:,.0f}".format(kpis.total_errors) }}</div>
    <div class="k">Failed levels / SQL errors</div></div>
</div>
{% endif %}

<h2 id="overview"><span class="secno">1</span>Run overview</h2>
<div class="card soft">
  <div class="meta-grid">
    <div><b>Status:</b> <span class="badge {{ manifest.status }}">{{ manifest.status }}</span></div>
    <div><b>Started (UTC):</b> {{ manifest.created_utc }}</div>
    <div><b>Finished (UTC):</b> {{ manifest.finished_utc or "n/a" }}</div>
    <div><b>Total wall time:</b> {{ wall_time }}</div>
    <div><b>Target:</b> {{ spec.target.host }}:{{ spec.target.port }}/{{ spec.target.database }}</div>
    {% if preflight.max_connections %}<div><b>Server max_connections:</b> {{ preflight.max_connections }}</div>{% endif %}
    {% if dataset.actual_size is not none %}<div><b>Dataset:</b> {{ dataset.actual_size }} {{ dataset.size_unit }}</div>{% endif %}
    {% if dataset.search_path %}<div><b>search_path:</b> <code>{{ dataset.search_path }}</code></div>{% endif %}
    <div><b>PostgreSQL:</b> {{ env.server_version }}</div>
    <div><b>sysbench:</b> {{ env.sysbench_version }}</div>
    <div><b>tpcc SHA:</b> {{ env.tpcc_git_sha }}</div>
    <div><b>Harness:</b> {{ env.harness_version }}</div>
    <div><b>Sweep:</b> threads {{ spec.sweep.threads | list }}, {{ spec.sweep.duration_s }}s per level, {{ spec.sweep.repetitions }} rep(s)</div>
    <div><b>Steady-state window:</b> {{ steady_window }} per level (first {{ spec.sweep.warmup_s }}s discarded as warm-up)</div>
    <div><b>Workload:</b> {{ spec.workload.type }}
      ({{ spec.workload.tables }} tables,
      {% if spec.workload.type == "tpcc" %}scale {{ spec.workload.scale }}{% else %}table_size {{ "{:,}".format(spec.workload.table_size) }}{% endif %})</div>
  </div>
  {% if spec.run.notes %}<p style="margin-bottom:0"><b>Notes:</b> {{ spec.run.notes }}</p>{% endif %}
</div>

{% if prepare_stats %}
<div class="card">
  <h3 style="margin-top:0">Data load (from <code>prepare</code>)</h3>
  <div class="meta-grid">
    <div><b>Loaded:</b> {{ prepare_stats.loaded_units }}</div>
    <div><b>Load wall time:</b> {{ prepare_stats.wall_s }}s</div>
    <div><b>Database size after load:</b> {{ prepare_stats.db_size_pretty }}</div>
    <div><b>Avg load throughput:</b> {% if prepare_stats.load_mb_s %}{{ prepare_stats.load_mb_s }} MB/s{% else %}n/a{% endif %}</div>
    <div><b>Load threads:</b> {{ prepare_stats.load_threads }}</div>
    <div><b>Loaded at (UTC):</b> {{ prepare_stats.finished_utc }}</div>
  </div>
</div>
{% endif %}

{% if warnings %}
<div class="warnbox"><b>Preflight warnings:</b>
  <ul style="margin:6px 0 0">{% for w in warnings %}<li>{{ w }}</li>{% endfor %}</ul>
</div>
{% endif %}

<div class="note">
  All aggregates below are computed over the steady-state window only ({{ steady_window }} of each level).
  Interval-line latency reflects only sysbench's <code>--percentile=99</code>; other percentiles
  (p{{ percentiles | join(", p") }}) are interpolated from the <code>--histogram</code> latency distribution.
</div>

{# ── 2. Headline table ──────────────────────────────────────────── #}
<h2 id="headline"><span class="secno">2</span>Headline results</h2>
<div class="table-wrap">
<table>
  <thead>
  <tr>
    <th>Threads</th><th>QPS (mean)</th><th>TPS (mean)</th>
    {% for p in percentiles %}<th>lat p{{ p }} (ms)</th>{% endfor %}
    <th>lat max (ms)</th><th>err/s</th><th>reconn/s</th><th>rep Δ QPS %</th>
  </tr>
  </thead>
  <tbody>
  {% for row in headline %}
  {% if row.qps is defined %}
  <tr>
    <td>{{ row.threads }}{% if row.failed_reps %} <span class="subtle">(rep {{ row.failed_reps | join(', ') }} FAILED)</span>{% endif %}</td>
    <td>{{ "{:,.0f}".format(row.qps) }}</td>
    <td>{{ "{:,.0f}".format(row.tps) }}</td>
    {% for p in percentiles %}<td>{{ "%.2f" | format(row["lat_p" ~ p]) if row["lat_p" ~ p] is not none else "—" }}</td>{% endfor %}
    <td>{{ "%.1f" | format(row.lat_max) if row.lat_max is not none else "—" }}</td>
    <td>{{ "%.2f" | format(row.err_s) }}</td>
    <td>{{ "%.2f" | format(row.reconn_s) }}</td>
    <td {% if row.variance_warn %}class="warn"{% endif %}>
      {{ "%.1f" | format(row.variance_pct) if row.variance_pct is not none else "—" }}</td>
  </tr>
  {% else %}
  <tr class="fail">
    <td>{{ row.threads }}</td>
    <td colspan="{{ 6 + percentiles | length }}">FAILED — {{ (row.error_excerpt or "no error captured") | truncate(180) }}</td>
  </tr>
  {% endif %}
  {% endfor %}
  </tbody>
</table>
</div>
<p class="subtle">rep Δ QPS % = (max − min) / mean across repetitions; highlighted when above
{{ spec.report.variance_warn_pct }}% (report.variance_warn_pct).</p>

{# ── 3. Throughput charts ───────────────────────────────────────── #}
<h2 id="throughput"><span class="secno">3</span>Throughput</h2>
{% if charts.qps %}<div class="chart"><img alt="QPS vs threads" src="{{ charts.qps }}"></div>{% else %}<p class="subtle">No successful levels to chart.</p>{% endif %}
{% if charts.tps %}<div class="chart"><img alt="TPS vs threads" src="{{ charts.tps }}"></div>{% endif %}

{# ── 4. Latency chart ───────────────────────────────────────────── #}
<h2 id="latency"><span class="secno">4</span>Latency</h2>
{% if charts.latency %}<div class="chart"><img alt="Latency percentiles vs threads" src="{{ charts.latency }}"></div>{% else %}<p class="subtle">No latency data to chart.</p>{% endif %}

{# ── 5. Stability charts ────────────────────────────────────────── #}
<h2 id="stability"><span class="secno">5</span>Stability (QPS over time)</h2>
{% if charts.timeseries %}
  {% for ts in charts.timeseries %}
    {% if ts.img %}<div class="chart"><img alt="QPS over time at {{ ts.threads }} threads" src="{{ ts.img }}"></div>
    {% else %}<p class="subtle">No samples captured for {{ ts.threads }} threads.</p>{% endif %}
  {% endfor %}
{% else %}
<p class="subtle">No timeseries levels configured (report.timeseries_levels).</p>
{% endif %}

{# ── 6. Errors & limits ─────────────────────────────────────────── #}
<h2 id="errors"><span class="secno">6</span>Errors &amp; limits</h2>
{% if errors.failed_levels %}
<h3>Failed levels</h3>
<div class="table-wrap">
<table>
  <thead><tr><th>Rep</th><th>Threads</th><th>First error lines (verbatim)</th></tr></thead>
  <tbody>
  {% for l in errors.failed_levels %}
  <tr class="fail"><td>{{ l.rep }}</td><td>{{ l.threads }}</td>
    <td style="text-align:left"><pre style="margin:0">{{ l.error_excerpt or "no error captured" }}</pre></td></tr>
  {% endfor %}
  </tbody>
</table>
</div>
{% endif %}
{% if errors.bad_interval_count %}
<h3>Intervals with errors / reconnects ({{ errors.bad_interval_count }} total{% if errors.bad_interval_count > 200 %}, first 200 shown{% endif %})</h3>
<div class="table-wrap">
<table>
  <thead><tr><th>Rep</th><th>Threads</th><th>t (s)</th><th>err/s</th><th>reconn/s</th><th>QPS</th></tr></thead>
  <tbody>
  {% for s in errors.bad_intervals %}
  <tr><td>{{ s.rep }}</td><td>{{ s.threads }}</td><td>{{ s.t_offset }}</td>
      <td>{{ s.err_s }}</td><td>{{ s.reconn_s }}</td><td>{{ "{:,.0f}".format(s.qps) }}</td></tr>
  {% endfor %}
  </tbody>
</table>
</div>
{% endif %}
{% if not errors.failed_levels and not errors.bad_interval_count %}
<p>No failed levels, no nonzero err/s or reconn/s intervals.</p>
{% endif %}

{# ── 7. Configuration appendix ──────────────────────────────────── #}
<h2 id="config"><span class="secno">7</span>Configuration appendix</h2>
<h3>Key settings</h3>
<div class="table-wrap">
<table class="settings cfg">
  <thead><tr><th>Setting</th><th>Value</th><th>Unit</th><th>Source</th></tr></thead>
  <tbody>
  {% for s in key_settings %}
  <tr><td>{{ s.name }}</td><td>{{ s.setting }}</td><td>{{ s.unit or "" }}</td><td>{{ s.source or "" }}</td></tr>
  {% endfor %}
  </tbody>
</table>
</div>
{% if all_settings %}
<details>
  <summary>Full pg_settings dump ({{ all_settings | length }} rows)</summary>
  <div class="table-wrap">
  <table class="settings cfg">
    <thead><tr><th>Setting</th><th>Value</th><th>Unit</th><th>Source</th></tr></thead>
    <tbody>
    {% for s in all_settings %}
    <tr><td>{{ s.name }}</td><td>{{ s.setting }}</td><td>{{ s.unit or "" }}</td><td>{{ s.source or "" }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  </div>
</details>
{% else %}
<p class="subtle">pg_settings capture disabled or unavailable for this run.</p>
{% endif %}
<details>
  <summary>Load generator host info</summary>
  <pre>{{ env.host_info }}</pre>
</details>
</main>

<footer>Generated by {{ env.harness_version }} — run {{ manifest.run_id }}.</footer>
</body>
</html>
